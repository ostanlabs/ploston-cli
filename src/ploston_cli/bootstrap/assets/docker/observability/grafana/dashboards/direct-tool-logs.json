      "id": 1,
      "title": "Direct Tool Call Logs",
      "description": "All direct tool call events. Filter by Level, Tool, Runner, or type anything in Search to match against any field in the log line (regex). Sorted oldest-first for chronological session reading. Expand any line to see full JSON fields.",
      "type": "logs",
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"h": 16, "w": 24, "x": 0, "y": 0},
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "sortOrder": "Ascending",
        "wrapLogMessage": true,
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false
      },
      "targets": [{
        "expr": "{job=\"ploston/ael\", ael_source=\"tool\"} | json | level=~\"($level)\" | ael_bridge=~\"($bridge|)\" | ael_tool_name=~\"($tool_name|)\" | ael_runner_id=~\"($runner|)\" |~ \"$search\"",
        "refId": "A"
      }]
    },
    {
      "id": 2,
      "title": "Errors — always shown (not affected by Level filter)",
      "description": "Hardcoded to ERROR level. Remains visible even when Level is set to INFO or WARN. Shows direct_tool_failed events with error and error_type. Search filter still applies.",
