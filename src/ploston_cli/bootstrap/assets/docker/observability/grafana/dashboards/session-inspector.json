            "percent"
          ]
        },
        "tooltip": {
          "mode": "single",
          "sort": "desc"
        },
        "pieType": "donut",
        "displayLabels": [
          "percent"
        ],
        "reduceOptions": {
          "calcs": [
            "sum"
          ],
          "fields": "/^calls$/",
          "values": true
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse"
          },
          "refId": "A",
          "format": 1,
          "rawSql": "SELECT tool_name, count() AS calls FROM ploston.tool_calls WHERE session_id = '$session_id' AND source IN ('direct', 'wrapped') AND $__timeFilter(started_at) GROUP BY tool_name ORDER BY calls DESC"
        }
      ]
    },
    {
      "id": 200,
      "type": "row",
      "title": "Workflow Executions",
