      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 31
      },
      "panels": [
        {
          "id": 2,
          "title": "Workflow Executions",
          "description": "Workflow runs that ran inside this session.",
          "type": "table",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse"
          },
          "gridPos": {
            "h": 8,
            "w": 24,
            "x": 0,
            "y": 32
          },
          "options": {
            "showHeader": true,
            "cellHeight": "sm"
          },
          "targets": [
            {
              "datasource": {
                "type": "grafana-clickhouse-datasource",
                "uid": "clickhouse"
              },
              "refId": "A",
              "format": 1,
              "rawSql": "SELECT started_at, execution_id, workflow_id, status, duration_ms, step_count, tool_call_count, coalesce(error_message, '') AS error FROM ploston.executions WHERE session_id = '$session_id' AND (execution_type = 'workflow' OR workflow_id != '') AND $__timeFilter(started_at) ORDER BY started_at DESC"
            }
          ],
          "fieldConfig": {
            "overrides": [
              {
                "matcher": {
                  "id": "byName",
                  "options": "execution_id"
                },
                "properties": [
                  {
                    "id": "links",
                    "value": [
                      {
                        "title": "View Workflow Execution Logs",
                        "url": "/d/ploston-workflow-execution-logs/workflow-execution-logs?var-execution_id=${__value.text}&${__url_time_range}",
                        "targetBlank": true
                      }
                    ]
                  }
                ]
              }
            ]
          }
        }
      ]
    },
