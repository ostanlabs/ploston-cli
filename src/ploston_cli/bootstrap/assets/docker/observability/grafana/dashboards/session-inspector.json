      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse"
          },
          "refId": "A",
          "format": 1,
          "rawSql": "SELECT countIf(error_code IS NOT NULL AND error_code != '') FROM ploston.tool_calls WHERE session_id = '$session_id' AND source IN ('direct', 'wrapped', 'wrapper') AND $__timeFilter(started_at)"
        }
      ]
    },
    {
