    {
      "id": 3,
      "title": "Tool Call Timeline",
      "description": "All tool calls for the selected session. The 'kind' column distinguishes 'direct' (a normal tool call), 'wrapper' (a workflow_call_tool or workflow_run that fans out into other calls), and 'wrapped' (a child tool call dispatched by a wrapper). Wrappers are rendered as parent rows with their wrapped children indented (\u2514\u2500) underneath, sharing the same execution_id. Sort by 'started_at' to see the raw chronological stream instead.",
      "type": "table",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 17
      },
      "options": {
        "showHeader": true,
        "cellHeight": "lg"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          },
          "links": []
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "started_at"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 160
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "kind"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 70
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "tool_name"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 250
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "mcp_server"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "runner_id"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "duration_ms"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Duration"
              },
              {
                "id": "unit",
                "value": "ms"
              },
              {
                "id": "custom.width",
                "value": 100
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "response_tokens"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "~Tokens"
              },
              {
                "id": "custom.width",
                "value": 90
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "status"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 80
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "source"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 80
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "params"
            },
            "properties": [
              {
                "id": "custom.inspect",
                "value": true
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "result"
            },
            "properties": [
              {
                "id": "custom.inspect",
                "value": true
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "error_message"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 200
              },
              {
                "id": "custom.inspect",
                "value": true
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "execution_id"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              },
              {
                "id": "links",
                "value": [
                  {
                    "title": "View in Call Inspector",
                    "url": "/d/ploston-call-inspector/call-inspector?var-session_id=${__data.fields.session_id}&var-call_id=${__value.text}&${__url_time_range}",
                    "targetBlank": true
                  }
                ]
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse"
          },
          "refId": "A",
          "format": 1,
          "rawSql": "WITH base AS (SELECT started_at, tool_name, runner_id, duration_ms, response_bytes, error_code, error_message, source, params, result, execution_id, splitByString('__', tool_name) AS _parts, length(splitByString('__', tool_name)) AS _nparts FROM ploston.tool_calls WHERE session_id = '$session_id' AND source IN ('direct', 'wrapper', 'wrapped') AND $__timeFilter(started_at)) SELECT started_at, source AS kind, multiIf(source = 'wrapped', concat('\u2514\u2500\u2500 ', multiIf(_nparts >= 3, arrayElement(_parts, _nparts), _nparts = 2, arrayElement(_parts, 2), tool_name)), multiIf(_nparts >= 3, arrayElement(_parts, _nparts), _nparts = 2, arrayElement(_parts, 2), tool_name)) AS tool_name, multiIf(_nparts >= 3, arrayElement(_parts, 2), _nparts = 2, arrayElement(_parts, 1), '') AS mcp_server, runner_id, duration_ms, toUInt64(response_bytes / 4) AS response_tokens, coalesce(if(error_code = '', NULL, error_code), 'ok') AS status, source, if(length(params) > 65536, concat(substring(params, 1, 65536), ' ... [truncated, ', toString(length(params)), ' bytes total]'), params) AS params, if(length(result) > 65536, concat(substring(result, 1, 65536), ' ... [truncated, ', toString(length(result)), ' bytes total]'), result) AS result, coalesce(error_message, '') AS error_message, execution_id FROM base ORDER BY started_at ASC"
        }
      ]
    },
    {
      "id": 5,
