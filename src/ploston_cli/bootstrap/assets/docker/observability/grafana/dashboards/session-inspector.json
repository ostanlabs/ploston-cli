  "panels": [
    {
      "id": 100,
      "title": "Recent Sessions",
      "description": "Click a session_id row to drill in. Solves the 'how does the user get a session_id' problem (S-299).",
      "type": "table",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          },
          "links": []
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "session_id"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Inspect this session",
                    "url": "/d/${__dashboard.uid}/agent-session-inspector?var-session_id=${__data.fields.session_id:percentencode}"
                  }
                ]
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse"
          },
          "refId": "A",
          "format": 1,
          "rawSql": "SELECT session_id, min(started_at) AS first_seen, max(started_at) AS last_seen, countIf(source != 'wrapper') AS tool_calls, countDistinctIf(tool_name, source != 'wrapper') AS unique_tools, countIf(error_code IS NOT NULL AND error_code != '') AS errors FROM ploston.tool_calls WHERE session_id IS NOT NULL AND session_id != '' AND source IN ('direct', 'wrapped', 'wrapper') AND $__timeFilter(started_at) GROUP BY session_id ORDER BY last_seen DESC LIMIT 50"
        }
      ]
    },
    {
      "id": 11,
      "title": "Tool Calls",
      "type": "stat",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 12,
        "y": 9
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse"
          },
          "refId": "A",
          "format": 1,
          "rawSql": "SELECT count() FROM ploston.tool_calls WHERE session_id = '$session_id' AND source IN ('direct', 'wrapped') AND $__timeFilter(started_at)"
        }
      ]
    },
    {
      "id": 12,
